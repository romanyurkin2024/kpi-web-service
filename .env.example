# ─── App ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api

# ─── JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── Primary PostgreSQL (app database) ─────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kpi_db

# ─── External PostgreSQL integration ───────────────
EXT_PG_ENABLED=false
EXT_PG_HOST=
EXT_PG_PORT=5432
EXT_PG_USER=
EXT_PG_PASSWORD=
EXT_PG_DATABASE=

# ─── Oracle integration ─────────────────────────────
ORACLE_ENABLED=false
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_SERVICE_NAME=

# ─── Admin seed ────────────────────────────────────
ADMIN_EMAIL=admin@kpi.local
ADMIN_PASSWORD=change_me_admin_password
