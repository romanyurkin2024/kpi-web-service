{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@kpi/shared": ["packages/shared/src/index.ts"],
      "@kpi/config": ["packages/config/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
